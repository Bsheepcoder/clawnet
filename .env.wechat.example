# 微信环境变量配置示例

# 微信公众号配置（请填入你的实际配置）
WECHAT_APPID=your_wechat_appid_here
WECHAT_APPSECRET=your_wechat_appsecret_here
WECHAT_TOKEN=your_wechat_token_here
WECHAT_ENCODING_AES_KEY=your_encoding_aes_key_here

# 配置说明：
#
# WECHAT_APPID
# - 微信公众号 AppID
# - 格式：以 wx 开头的字符串
# - 示例：wx1234567890abcdef
#
# WECHAT_APPSECRET
# - 微信公众号 AppSecret
# - 格式：32位字符串
# - 获取：微信公众号后台 → 基本配置
#
# WECHAT_TOKEN
# - 微信服务器验证 Token
# - 只能包含：英文字母、数字
# - 长度：3-32字符
# - 不能有：横线(-)、下划线(_)、空格等特殊字符
# - 正确示例：clawnet, mytoken123, wechat2026
# - 错误示例：clawnet-mp, my_token, token 123
#
# WECHAT_ENCODING_AES_KEY
# - 消息加密密钥
# - 格式：43位字符串
# - 获取：微信公众号后台 → 基本配置 → 消息加密
