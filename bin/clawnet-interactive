#!/usr/bin/env node
/**
 * ClawNet Interactive CLI
 * 友好的交互式命令行工具
 */

const chalk = require('chalk');
const inquirer = require('inquirer');
const ora = require('ora');
const fs = require('fs');
const path = require('path');

const CLAWNET_URL = process.env.CLAWNET_URL || 'http://localhost:3000';
const CONFIG_FILE = path.join(process.env.HOME || process.env.USERPROFILE, '.clawnetrc');

// 加载配置
function loadConfig() {
  try {
    if (fs.existsSync(CONFIG_FILE)) {
      return JSON.parse(fs.readFileSync(CONFIG_FILE, 'utf8'));
    }
  } catch (error) {
    // 忽略错误
  }
  return {};
}

// 保存配置
function saveConfig(config) {
  try {
    fs.writeFileSync(CONFIG_FILE, JSON.stringify(config, null, 2));
  } catch (error) {
    // 忽略错误
  }
}

const config = loadConfig();
const CLAWNET_TOKEN = process.env.CLAWNET_TOKEN || config.token || 'clawnet-secret-token';

// API 请求
async function request(endpoint, options = {}) {
  const url = `${CLAWNET_URL}${endpoint}`;
  const headers = {
    'Content-Type': 'application/json',
    'Authorization': `Bearer ${CLAWNET_TOKEN}`,
    ...options.headers
  };

  const response = await fetch(url, { ...options, headers });
  const result = await response.json();
  
  if (!response.ok) {
    throw new Error(result.error || response.statusText);
  }

  return result;
}

// 显示欢迎信息
function showWelcome() {
  console.log();
  console.log(chalk.cyan.bold('╔═══════════════════════════════════════╗'));
  console.log(chalk.cyan.bold('║') + chalk.white.bold('       🤖 ClawNet Interactive CLI       ') + chalk.cyan.bold('║'));
  console.log(chalk.cyan.bold('║') + chalk.gray('    Relation-Driven Collaboration       ') + chalk.cyan.bold('║'));
  console.log(chalk.cyan.bold('╚═══════════════════════════════════════╝'));
  console.log();
  console.log(chalk.gray('  版本: 0.5.0'));
  console.log(chalk.gray('  文档: https://github.com/Bsheepcoder/ClawNet'));
  console.log();
}

// 主菜单
async function mainMenu() {
  const { action } = await inquirer.prompt([
    {
      type: 'list',
      name: 'action',
      message: '选择操作:',
      choices: [
        { name: '📦 节点管理', value: 'nodes' },
        { name: '🔗 关系管理', value: 'relations' },
        { name: '🔐 权限管理', value: 'permissions' },
        { name: '📡 实时监控', value: 'monitor' },
        { name: '⚙️  配置管理', value: 'config' },
        { name: '📊 系统状态', value: 'status' },
        { name: '❓ 帮助', value: 'help' },
        new inquirer.Separator(),
        { name: '🚪 退出', value: 'exit' }
      ]
    }
  ]);

  return action;
}

// 节点管理菜单
async function nodeMenu() {
  const { action } = await inquirer.prompt([
    {
      type: 'list',
      name: 'action',
      message: '节点管理:',
      choices: [
        { name: '➕ 创建节点', value: 'create' },
        { name: '📋 查看所有节点', value: 'list' },
        { name: '🔍 查看节点详情', value: 'get' },
        { name: '✏️  更新节点', value: 'update' },
        { name: '🗑️  删除节点', value: 'delete' },
        { name: '📤 导出节点', value: 'export' },
        { name: '📥 导入节点', value: 'import' },
        new inquirer.Separator(),
        { name: '🔙 返回主菜单', value: 'back' }
      ]
    }
  ]);

  switch (action) {
    case 'create':
      await createNode();
      break;
    case 'list':
      await listNodes();
      break;
    case 'get':
      await getNode();
      break;
    case 'update':
      await updateNode();
      break;
    case 'delete':
      await deleteNode();
      break;
    case 'export':
      await exportNodes();
      break;
    case 'import':
      await importNodes();
      break;
    case 'back':
      return;
  }

  await nodeMenu();
}

// 创建节点
async function createNode() {
  const answers = await inquirer.prompt([
    {
      type: 'input',
      name: 'id',
      message: '节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    },
    {
      type: 'input',
      name: 'name',
      message: '节点名称:',
      default: (answers) => answers.id
    },
    {
      type: 'list',
      name: 'type',
      message: '节点类型:',
      choices: ['bot', 'human', 'device', 'org', 'system'],
      default: 'bot'
    },
    {
      type: 'confirm',
      name: 'addMetadata',
      message: '添加元数据?',
      default: false
    }
  ]);

  let metadata = {};
  if (answers.addMetadata) {
    const { metadataStr } = await inquirer.prompt([
      {
        type: 'editor',
        name: 'metadataStr',
        message: '输入元数据 (JSON 格式):',
        default: '{}'
      }
    ]);
    try {
      metadata = JSON.parse(metadataStr);
    } catch (error) {
      console.log(chalk.yellow('⚠️  元数据格式错误，将使用空对象'));
    }
  }

  const spinner = ora('创建节点...').start();

  try {
    const result = await request('/nodes', {
      method: 'POST',
      body: JSON.stringify({
        id: answers.id,
        name: answers.name,
        type: answers.type,
        metadata
      })
    });

    spinner.succeed(chalk.green('✅ 节点创建成功'));
    
    console.log();
    console.log(chalk.cyan('  节点信息:'));
    console.log(chalk.gray(`  ID:   ${result.data.id}`));
    console.log(chalk.gray(`  名称: ${result.data.name}`));
    console.log(chalk.gray(`  类型: ${result.data.type}`));
    console.log();
  } catch (error) {
    spinner.fail(chalk.red(`❌ 创建失败: ${error.message}`));
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// 列出所有节点
async function listNodes() {
  const spinner = ora('加载节点列表...').start();

  try {
    const result = await request('/nodes');
    spinner.succeed();

    if (result.data.length === 0) {
      console.log(chalk.yellow('\n  暂无节点\n'));
      return;
    }

    console.log();
    console.log(chalk.cyan(`  📋 节点列表 (${result.data.length} 个):`));
    console.log();

    // 按类型分组
    const grouped = {};
    result.data.forEach(node => {
      if (!grouped[node.type]) {
        grouped[node.type] = [];
      }
      grouped[node.type].push(node);
    });

    // 显示分组
    const typeEmojis = {
      bot: '🤖',
      human: '👤',
      device: '📱',
      org: '🏢',
      system: '⚙️'
    };

    for (const [type, nodes] of Object.entries(grouped)) {
      console.log(chalk.cyan(`  ${typeEmojis[type] || '📦'} ${type.toUpperCase()}`));
      nodes.forEach(node => {
        console.log(chalk.gray(`    • ${node.id} (${node.name})`));
      });
      console.log();
    }
  } catch (error) {
    spinner.fail(chalk.red(`❌ 加载失败: ${error.message}`));
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// 查看节点详情
async function getNode() {
  const { id } = await inquirer.prompt([
    {
      type: 'input',
      name: 'id',
      message: '节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    }
  ]);

  const spinner = ora('加载节点详情...').start();

  try {
    const result = await request(`/nodes/${id}`);
    spinner.succeed();

    console.log();
    console.log(chalk.cyan('  📄 节点详情:'));
    console.log();
    console.log(chalk.gray(`  ID:     ${result.data.id}`));
    console.log(chalk.gray(`  名称:   ${result.data.name}`));
    console.log(chalk.gray(`  类型:   ${result.data.type}`));
    console.log(chalk.gray(`  创建:   ${new Date(result.data.createdAt).toLocaleString()}`));
    
    if (result.data.metadata && Object.keys(result.data.metadata).length > 0) {
      console.log();
      console.log(chalk.cyan('  元数据:'));
      console.log(chalk.gray(JSON.stringify(result.data.metadata, null, 4)));
    }
    console.log();
  } catch (error) {
    spinner.fail(chalk.red(`❌ 加载失败: ${error.message}`));
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// 更新节点
async function updateNode() {
  const { id } = await inquirer.prompt([
    {
      type: 'input',
      name: 'id',
      message: '节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    }
  ]);

  const spinner = ora('加载节点信息...').start();

  try {
    const result = await request(`/nodes/${id}`);
    spinner.succeed();

    const node = result.data;

    const answers = await inquirer.prompt([
      {
        type: 'input',
        name: 'name',
        message: '节点名称:',
        default: node.name
      },
      {
        type: 'list',
        name: 'type',
        message: '节点类型:',
        choices: ['bot', 'human', 'device', 'org', 'system'],
        default: node.type
      }
    ]);

    const updateSpinner = ora('更新节点...').start();

    await request(`/nodes/${id}`, {
      method: 'PUT',
      body: JSON.stringify(answers)
    });

    updateSpinner.succeed(chalk.green('✅ 节点已更新'));
  } catch (error) {
    spinner.fail(chalk.red(`❌ 操作失败: ${error.message}`));
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// 删除节点
async function deleteNode() {
  const { id } = await inquirer.prompt([
    {
      type: 'input',
      name: 'id',
      message: '节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    }
  ]);

  const { confirm } = await inquirer.prompt([
    {
      type: 'confirm',
      name: 'confirm',
      message: `确定删除节点 "${id}"?`,
      default: false
    }
  ]);

  if (!confirm) {
    console.log(chalk.yellow('\n  操作已取消\n'));
    return;
  }

  const spinner = ora('删除节点...').start();

  try {
    await request(`/nodes/${id}`, { method: 'DELETE' });
    spinner.succeed(chalk.green(`✅ 节点已删除: ${id}`));
  } catch (error) {
    spinner.fail(chalk.red(`❌ 删除失败: ${error.message}`));
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// 导出节点
async function exportNodes() {
  const { filename } = await inquirer.prompt([
    {
      type: 'input',
      name: 'filename',
      message: '导出文件名:',
      default: `clawnet-nodes-${Date.now()}.json`
    }
  ]);

  const spinner = ora('导出节点...').start();

  try {
    const result = await request('/nodes');
    fs.writeFileSync(filename, JSON.stringify(result.data, null, 2));
    spinner.succeed(chalk.green(`✅ 已导出到 ${filename}`));
  } catch (error) {
    spinner.fail(chalk.red(`❌ 导出失败: ${error.message}`));
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// 导入节点
async function importNodes() {
  const { filename } = await inquirer.prompt([
    {
      type: 'input',
      name: 'filename',
      message: '导入文件名:',
      validate: (input) => {
        if (!fs.existsSync(input)) {
          return '文件不存在';
        }
        return true;
      }
    }
  ]);

  const spinner = ora('导入节点...').start();

  try {
    const nodes = JSON.parse(fs.readFileSync(filename, 'utf8'));
    let imported = 0;

    for (const node of nodes) {
      try {
        await request('/nodes', {
          method: 'POST',
          body: JSON.stringify(node)
        });
        imported++;
      } catch (error) {
        // 忽略单个失败
      }
    }

    spinner.succeed(chalk.green(`✅ 已导入 ${imported}/${nodes.length} 个节点`));
  } catch (error) {
    spinner.fail(chalk.red(`❌ 导入失败: ${error.message}`));
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// 关系管理菜单
async function relationMenu() {
  const { action } = await inquirer.prompt([
    {
      type: 'list',
      name: 'action',
      message: '关系管理:',
      choices: [
        { name: '➕ 创建关系', value: 'create' },
        { name: '📋 查看所有关系', value: 'list' },
        { name: '⏱️  创建临时关系 (TTL)', value: 'create-ttl' },
        { name: '🔍 查看关系详情', value: 'get' },
        { name: '🗑️  删除关系', value: 'delete' },
        { name: '🧹 清理过期关系', value: 'cleanup' },
        new inquirer.Separator(),
        { name: '🔙 返回主菜单', value: 'back' }
      ]
    }
  ]);

  switch (action) {
    case 'create':
      await createRelation();
      break;
    case 'list':
      await listRelations();
      break;
    case 'create-ttl':
      await createTTLRelation();
      break;
    case 'get':
      await getRelation();
      break;
    case 'delete':
      await deleteRelation();
      break;
    case 'cleanup':
      await cleanupRelations();
      break;
    case 'back':
      return;
  }

  await relationMenu();
}

// 创建关系
async function createRelation() {
  const answers = await inquirer.prompt([
    {
      type: 'input',
      name: 'from',
      message: '源节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    },
    {
      type: 'input',
      name: 'to',
      message: '目标节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    },
    {
      type: 'list',
      name: 'type',
      message: '关系类型:',
      choices: ['observe', 'manage', 'collaborate', 'delegate'],
      default: 'observe'
    },
    {
      type: 'checkbox',
      name: 'permissions',
      message: '权限:',
      choices: [
        { name: 'read', checked: true },
        { name: 'write', checked: false },
        { name: 'admin', checked: false }
      ]
    }
  ]);

  const spinner = ora('创建关系...').start();

  try {
    const result = await request('/relations', {
      method: 'POST',
      body: JSON.stringify(answers)
    });

    spinner.succeed(chalk.green('✅ 关系创建成功'));
    
    console.log();
    console.log(chalk.cyan('  关系信息:'));
    console.log(chalk.gray(`  ${result.data.from} → ${result.data.to}`));
    console.log(chalk.gray(`  类型: ${result.data.type}`));
    console.log(chalk.gray(`  权限: ${result.data.permissions.join(', ')}`));
    console.log();
  } catch (error) {
    spinner.fail(chalk.red(`❌ 创建失败: ${error.message}`));
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// 列出所有关系
async function listRelations() {
  const spinner = ora('加载关系列表...').start();

  try {
    const result = await request('/relations');
    spinner.succeed();

    if (result.data.length === 0) {
      console.log(chalk.yellow('\n  暂无关系\n'));
      return;
    }

    console.log();
    console.log(chalk.cyan(`  🔗 关系列表 (${result.data.length} 个):`));
    console.log();

    result.data.forEach(rel => {
      const status = rel.isTemporary ? 
        chalk.yellow(`(临时, ${Math.round((rel.expiresAt - Date.now()) / 1000)}s)`) : 
        chalk.green('(永久)');
      
      console.log(chalk.gray(`  • ${rel.from} → ${rel.to} ${status}`));
      console.log(chalk.gray(`    类型: ${rel.type} | 权限: ${rel.permissions.join(', ')}`));
      console.log();
    });
  } catch (error) {
    spinner.fail(chalk.red(`❌ 加载失败: ${error.message}`));
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// 创建临时关系
async function createTTLRelation() {
  const answers = await inquirer.prompt([
    {
      type: 'input',
      name: 'from',
      message: '源节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    },
    {
      type: 'input',
      name: 'to',
      message: '目标节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    },
    {
      type: 'list',
      name: 'type',
      message: '关系类型:',
      choices: ['observe', 'manage', 'collaborate', 'delegate'],
      default: 'observe'
    },
    {
      type: 'checkbox',
      name: 'permissions',
      message: '权限:',
      choices: [
        { name: 'read', checked: true },
        { name: 'write', checked: false },
        { name: 'admin', checked: false }
      ]
    },
    {
      type: 'number',
      name: 'ttl',
      message: '有效期 (秒):',
      default: 3600,
      validate: (input) => input > 0 || 'TTL 必须大于 0'
    }
  ]);

  const spinner = ora('创建临时关系...').start();

  try {
    const result = await request('/relations', {
      method: 'POST',
      body: JSON.stringify({
        ...answers,
        isTemporary: true,
        ttl: answers.ttl * 1000
      })
    });

    spinner.succeed(chalk.green('✅ 临时关系创建成功'));
    
    console.log();
    console.log(chalk.cyan('  关系信息:'));
    console.log(chalk.gray(`  ${result.data.from} → ${result.data.to}`));
    console.log(chalk.gray(`  类型: ${result.data.type}`));
    console.log(chalk.gray(`  权限: ${result.data.permissions.join(', ')}`));
    console.log(chalk.yellow(`  有效期: ${answers.ttl} 秒`));
    console.log();
  } catch (error) {
    spinner.fail(chalk.red(`❌ 创建失败: ${error.message}`));
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

