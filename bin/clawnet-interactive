// 配置管理
async function configMenu() {
  const { action } = await inquirer.prompt([
    {
      type: 'list',
      name: 'action',
      message: '配置管理:',
      choices: [
        { name: '🔧 配置服务器地址', value: 'server' },
        { name: '🔑 配置 Token', value: 'token' },
        { name: '📋 查看当前配置', value: 'view' },
        new inquirer.Separator(),
        { name: '🔙 返回主菜单', value: 'back' }
      ]
    }
  ]);

  switch (action) {
    case 'server':
      const { url } = await inquirer.prompt([
        {
          type: 'input',
          name: 'url',
          message: '服务器地址:',
          default: CLAWNET_URL
        }
      ]);
      config.url = url;
      saveConfig(config);
      console.log(chalk.green('\n  ✅ 已保存\n'));
      break;

    case 'token':
      const { token } = await inquirer.prompt([
        {
          type: 'password',
          name: 'token',
          message: 'API Token:',
          mask: '*'
        }
      ]);
      config.token = token;
      saveConfig(config);
      console.log(chalk.green('\n  ✅ 已保存\n'));
      break;

    case 'view':
      console.log();
      console.log(chalk.cyan('  当前配置:'));
      console.log(chalk.gray(`  服务器: ${config.url || CLAWNET_URL}`));
      console.log(chalk.gray(`  Token:  ${config.token ? '已配置' : '未配置'}`));
      console.log();
      break;

    case 'back':
      return;
  }

  await configMenu();
}

// 系统状态
async function showStatus() {
  const spinner = ora('检查系统状态...').start();

  try {
    const result = await request('/health');
    spinner.succeed();

    console.log();
    console.log(chalk.cyan('  📊 系统状态:'));
    console.log();
    console.log(chalk.gray(`  状态: ${result.status}`));
    console.log();
    console.log(chalk.cyan('  功能:'));
    console.log(chalk.gray(`  REST API:  ${result.features.rest ? '✅' : '❌'}`));
    console.log(chalk.gray(`  WebSocket: ${result.features.websocket ? '✅' : '❌'}`));
    console.log(chalk.gray(`  认证:      ${result.features.auth ? '✅' : '❌'}`));
    console.log();
    console.log(chalk.cyan('  统计:'));
    console.log(chalk.gray(`  节点数:    ${result.stats.nodes}`));
    console.log(chalk.gray(`  关系数:    ${result.stats.relations}`));
    console.log(chalk.gray(`  WS 连接:   ${result.stats.wsConnections}`));
    console.log();
  } catch (error) {
    spinner.fail(chalk.red(`❌ 连接失败: ${error.message}`));
    console.log();
    console.log(chalk.yellow('  💡 请确保 ClawNet 服务正在运行:'));
    console.log(chalk.gray('     npm start'));
    console.log();
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// 显示帮助
function showHelp() {
  console.log();
  console.log(chalk.cyan('  ❓ 帮助信息'));
  console.log();
  console.log(chalk.gray('  ClawNet 是一个关系驱动的多节点智能协作网络。'));
  console.log();
  console.log(chalk.cyan('  核心概念:'));
  console.log(chalk.gray('  • 节点 (Node): 人、机器人、设备、组织等实体'));
  console.log(chalk.gray('  • 关系 (Relation): 节点之间的连接'));
  console.log(chalk.gray('  • 权限 (Permission): 基于关系的访问控制'));
  console.log();
  console.log(chalk.cyan('  快速开始:'));
  console.log(chalk.gray('  1. 创建节点: 节点管理 → 创建节点'));
  console.log(chalk.gray('  2. 建立关系: 关系管理 → 创建关系'));
  console.log(chalk.gray('  3. 检查权限: 权限管理 → 检查权限'));
  console.log();
  console.log(chalk.cyan('  文档:'));
  console.log(chalk.gray('  https://github.com/Bsheepcoder/ClawNet'));
  console.log();
}

// 主程序
async function main() {
  showWelcome();

  while (true) {
    try {
      const action = await mainMenu();

      switch (action) {
        case 'nodes':
          await nodeMenu();
          break;
        case 'relations':
          await relationMenu();
          break;
        case 'permissions':
          await permissionMenu();
          break;
        case 'monitor':
          await monitorMenu();
          break;
        case 'config':
          await configMenu();
          break;
        case 'status':
          await showStatus();
          break;
        case 'help':
          showHelp();
          await inquirer.prompt([
            {
              type: 'input',
              name: 'continue',
              message: '按回车继续...'
            }
          ]);
          break;
        case 'exit':
          console.log();
          console.log(chalk.cyan('  再见! 👋'));
          console.log();
          process.exit(0);
      }
    } catch (error) {
      if (error.message === 'User force closed the prompt') {
        console.log();
        console.log(chalk.cyan('\n  再见! 👋\n'));
        process.exit(0);
      }
      console.error(chalk.red(`\n  错误: ${error.message}\n`));
    }
  }
}

main();
