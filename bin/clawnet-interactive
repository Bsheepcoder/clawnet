#!/usr/bin/env node
/**
 * ClawNet Interactive CLI
 * Enhanced Interactive Experience
 */

const chalk = require('chalk');
const inquirer = require('inquirer');
const ora = require('ora');
const fs = require('fs');
const path = require('path');
const packageJson = require('../package.json');

const CLAWNET_URL = process.env.CLAWNET_URL || 'http://localhost:3000';
const CONFIG_FILE = path.join(process.env.HOME || process.env.USERPROFILE, '.clawnetrc');

// ASCII Art Logo (fallback if figlet not available)
const showBanner = () => {
  console.log();
  try {
    const figlet = require('figlet');
    const banner = figlet.textSync('ClawNet', { 
      font: 'Standard',
      horizontalLayout: 'fitted',
      verticalLayout: 'default'
    });
    console.log(chalk.cyan(banner));
  } catch (error) {
    // Fallback: figlet not available
    console.log();
    console.log(chalk.cyan.bold('╔═══════════════════════════════════╗'));
    console.log(chalk.cyan.bold('  ║') + chalk.white.bold('       🤖 ClawNet CLI v' + packageJson.version.padEnd(13)) + chalk.cyan.bold('║'));
    console.log(chalk.cyan.bold('  ║') + chalk.gray('  Relation-Driven Collaboration Network  ') + chalk.cyan.bold('║'));
    console.log(chalk.cyan.bold('  ╚═══════════════════════════════════╝'));
  }
  console.log(chalk.gray('  Version: 0.5.3'));
  console.log();
};

// 配置管理
const loadConfig = () => {
  try {
    if (fs.existsSync(CONFIG_FILE)) {
      return JSON.parse(fs.readFileSync(CONFIG_FILE, 'utf8'));
    }
  } catch (error) {
    // 忽略错误
  }
  return {};
};

const saveConfig = (config) => {
  try {
    fs.writeFileSync(CONFIG_FILE, JSON.stringify(config, null, 2));
  } catch (error) {
    // 忽略错误
  }
};

const config = loadConfig();
const CLAWNET_TOKEN = process.env.CLAWNET_TOKEN || config.token || 'clawnet-secret-token';

// API 请求
async function request(endpoint, options = {}) {
  const url = `${CLAWNET_URL}${endpoint}`;
  const headers = {
    'Content-Type': 'application/json',
    'Authorization': `Bearer ${CLAWNET_TOKEN}`,
    ...options.headers
  };

  const response = await fetch(url, { ...options, headers });
  const result = await response.json();
  
  if (!response.ok) {
    throw new Error(result.error || response.statusText);
  }

  return result;
}

// 创建主命令
const { Command } = require('commander');

const program = new Command();

program
  .name('clawnet-interactive')
  .description('🎮 启动 ClawNet 交互式命令行界面')
  .option('-u, --url <url>', 'ClawNet 服务器地址', CLAWNET_URL)
  .option('-t, --token <token>', 'API Token', CLAWNET_TOKEN)
  .option('--no-color', '禁用彩色输出')
  .option('--no-banner', '禁用启动横幅')
  .hook('preAction', (thisCommand) => {
    const options = thisCommand.opts();
    if (options.url) process.env.CLAWNET_URL = options.url;
    if (options.token) process.env.CLAWNET_TOKEN = options.token;
  });

// ========== 主菜单 ==========
async function mainMenu() {
  if (!program.opts().noBanner) {
    showBanner();
  }

  const { action } = await inquirer.prompt([
    {
      type: 'list',
      name: 'action',
      message: '选择操作:',
      pageSize: 20,
      choices: [
        new inquirer.Separator('─── 📦 节点管理 ───'),
        { name: '➕ 创建节点', value: 'create-node' },
        { name: '📋 查看节点列表', value: 'list-nodes' },
        { name: '🔍 查看节点详情', value: 'get-node' },
        { name: '🗑️ 删除节点', value: 'delete-node' },
        
        new inquirer.Separator('─── 🔗 关系管理 ───'),
        { name: '➕ 创建关系', value: 'create-relation' },
        { name: '📋 查看关系列表', value: 'list-relations' },
        { name: '🧹 清理过期关系', value: 'cleanup-relations' },
        
        new inquirer.Separator('─── 🔐 权限管理 ───'),
        { name: '🔍 检查权限', value: 'check-permission' },
        
        new inquirer.Separator('─── 📊 系统管理 ───'),
        { name: '📊 系统状态', value: 'health' },
        { name: '📡 在线节点', value: 'list-online' },
        { name: '🔑 生成 Token', value: 'generate-token' },
        
        new inquirer.Separator('─── ⚙️ 配置管理 ───'),
        { name: '⚙️ 配置管理', value: 'config' },
        
        new inquirer.Separator('─── 📚 帮助 ───'),
        { name: '❓ 帮助信息', value: 'help' },
        new inquirer.Separator(),
        { name: '❌ 退出', value: 'exit' }
      ]
    }
  ]);

  return action;
}

// ========== 节点管理 ==========
async function createNode() {
  console.log();
  console.log(chalk.cyan.bold('➕ 创建节点'));
  console.log();

  const answers = await inquirer.prompt([
    {
      type: 'input',
      name: 'id',
      message: '节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    },
    {
      type: 'input',
      name: 'name',
      message: '节点名称:',
      default: (answers) => answers.id
    },
    {
      type: 'list',
      name: 'type',
      message: '节点类型:',
      choices: ['bot', 'human', 'device', 'org', 'system'],
      default: 'bot'
    },
    {
      type: 'confirm',
      name: 'addMetadata',
      message: '添加元数据?',
      default: false
    }
  ]);

  let metadata = {};
  if (answers.addMetadata) {
    const { metadataStr } = await inquirer.prompt([
      {
        type: 'editor',
        name: 'metadataStr',
        message: '输入元数据 (JSON 格式):',
        default: '{}'
      }
    ]);
    try {
      metadata = JSON.parse(metadataStr);
    } catch (error) {
      console.log(chalk.yellow('⚠️  元数据格式错误，将使用空对象'));
    }
  }

  const spinner = ora('创建节点...').start();

  try {
    const result = await request('/nodes', {
      method: 'POST',
      body: JSON.stringify({
        id: answers.id,
        name: answers.name,
        type: answers.type,
        metadata
      })
    });

    spinner.succeed(chalk.green('✅ 节点创建成功'));
    
    console.log();
    console.log(chalk.cyan('  节点信息:'));
    console.log(chalk.gray(`  ID:   ${result.data.id}`));
    console.log(chalk.gray(`  名称: ${result.data.name}`));
    console.log(chalk.gray(`  类型: ${result.data.type}`));
    console.log();
  } catch (error) {
    spinner.fail(chalk.red(`❌ 创建失败: ${error.message}`));
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// 列出节点
async function listNodes() {
  console.log();
  console.log(chalk.cyan.bold('📋 查看节点列表'));
  console.log();

  const spinner = ora('加载节点列表...').start();

  try {
    const result = await request('/nodes');
    spinner.succeed();

    if (result.data.length === 0) {
      console.log(chalk.yellow('\n  暂无节点\n'));
      await pressEnter();
      return;
    }

    console.log(chalk.cyan(`\n  📋 节点列表 (${result.data.length} 个):\n`));

    // 按类型分组
    const grouped = {};
    result.data.forEach(node => {
      if (!grouped[node.type]) grouped[node.type] = [];
      grouped[node.type].push(node);
    });

    const typeEmojis = { bot: '🤖', human: '👤', device: '📱', org: '🏢', system: '⚙️' };

    for (const [type, nodes] of Object.entries(grouped)) {
      console.log(chalk.cyan(`  ${typeEmojis[type] || '📦'} ${type.toUpperCase()}`));
      nodes.forEach(node => {
        console.log(chalk.gray(`    • ${node.id} (${node.name})`));
      });
      console.log();
    }
  } catch (error) {
    spinner.fail(chalk.red(`❌ 加载失败: ${error.message}`));
  }

  await pressEnter();
}

// 查看节点详情
async function getNode() {
  console.log();
  console.log(chalk.cyan.bold('🔍 查看节点详情'));
  console.log();

  const { id } = await inquirer.prompt([
    {
      type: 'input',
      name: 'id',
      message: '节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    }
  ]);

  const spinner = ora('加载节点详情...').start();

  try {
    const result = await request(`/nodes/${id}`);
    spinner.succeed();

    console.log();
    console.log(chalk.cyan('  📄 节点详情:\n'));
    console.log(chalk.gray(`  ID:     ${result.data.id}`));
    console.log(chalk.gray(`  名称:   ${result.data.name}`));
    console.log(chalk.gray(`  类型:   ${result.data.type}`));
    console.log(chalk.gray(`  创建:   ${new Date(result.data.createdAt).toLocaleString()}`));
    
    if (result.data.metadata && Object.keys(result.data.metadata).length > 0) {
      console.log();
      console.log(chalk.cyan('  元数据:'));
      console.log(chalk.gray(JSON.stringify(result.data.metadata, null, 4)));
    }
    console.log();
  } catch (error) {
    spinner.fail(chalk.red(`❌ 加载失败: ${error.message}`));
  }

  await pressEnter();
}

// 删除节点
async function deleteNode() {
  console.log();
  console.log(chalk.cyan.bold('🗑️  删除节点'));
  console.log();

  const { id } = await inquirer.prompt([
    {
      type: 'input',
      name: 'id',
      message: '节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    }
  ]);

  const { confirm } = await inquirer.prompt([
    {
      type: 'confirm',
      name: 'confirm',
      message: `确定删除节点 "${id}"?`,
      default: false
    }
  ]);

  if (!confirm) {
    console.log(chalk.yellow('\n  操作已取消\n'));
    await pressEnter();
    return;
  }

  const spinner = ora('删除节点...').start();

  try {
    await request(`/nodes/${id}`, { method: 'DELETE' });
    spinner.succeed(chalk.green(`✅ 节点已删除: ${id}`));
  } catch (error) {
    spinner.fail(chalk.red(`❌ 删除失败: ${error.message}`));
  }

  await pressEnter();
}

// ========== 关系管理 ==========
async function createRelation() {
  console.log();
  console.log(chalk.cyan.bold('➕ 创建关系'));
  console.log();

  const answers = await inquirer.prompt([
    {
      type: 'input',
      name: 'from',
      message: '源节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    },
    {
      type: 'input',
      name: 'to',
      message: '目标节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    },
    {
      type: 'list',
      name: 'type',
      message: '关系类型:',
      choices: ['observe', 'manage', 'collaborate', 'delegate'],
      default: 'observe'
    },
    {
      type: 'checkbox',
      name: 'permissions',
      message: '权限:',
      choices: [
        { name: 'read', checked: true },
        { name: 'write', checked: false },
        { name: 'admin', checked: false }
      ]
    }
  ]);

  const spinner = ora('创建关系...').start();

  try {
    const result = await request('/relations', {
      method: 'POST',
      body: JSON.stringify(answers)
    });

    spinner.succeed(chalk.green('✅ 关系创建成功'));
    
    console.log();
    console.log(chalk.cyan('  关系信息:'));
    console.log(chalk.gray(`  ${result.data.from} → ${result.data.to}`));
    console.log(chalk.gray(`  类型: ${result.data.type}`));
    console.log(chalk.gray(`  权限: ${result.data.permissions.join(', ')}`));
    console.log();
  } catch (error) {
    spinner.fail(chalk.red(`❌ 创建失败: ${error.message}`));
  }

  await pressEnter();
}

// 列出关系
async function listRelations() {
  console.log();
  console.log(chalk.cyan.bold('📋 查看关系列表'));
  console.log();

  const spinner = ora('加载关系列表...').start();

  try {
    const result = await request('/relations');
    spinner.succeed();

    if (result.data.length === 0) {
      console.log(chalk.yellow('\n  暂无关系\n'));
      await pressEnter();
      return;
    }

    console.log(chalk.cyan(`\n  🔗 关系列表 (${result.data.length} 个):\n`));

    result.data.forEach(rel => {
      const status = rel.isTemporary ? 
        chalk.yellow(`(临时, ${Math.round((rel.expiresAt - Date.now()) / 1000)}s)`) : 
        chalk.green('(永久)');
      
      console.log(chalk.gray(`  • ${rel.from} → ${rel.to} ${status}`));
      console.log(chalk.gray(`    类型: ${rel.type} | 权限: ${rel.permissions.join(', ')}`));
      console.log();
    });
  } catch (error) {
    spinner.fail(chalk.red(`❌ 加载失败: ${error.message}`));
  }

  await pressEnter();
}

// 清理过期关系
async function cleanupRelations() {
  console.log();
  console.log(chalk.cyan.bold('🧹 清理过期关系'));
  console.log();

  const { confirm } = await inquirer.prompt([
    {
      type: 'confirm',
      name: 'confirm',
      message: '确定清理所有过期关系?',
      default: true
    }
  ]);

  if (!confirm) {
    return;
  }

  const spinner = ora('清理过期关系...').start();

  try {
    const result = await request('/relations/cleanup', { method: 'POST' });
    spinner.succeed(chalk.green(`✅ 已清理 ${result.data.cleaned} 个过期关系`));
  } catch (error) {
    spinner.fail(chalk.red(`❌ 清理失败: ${error.message}`));
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// ========== 权限命令 ==========
async function checkPermission() {
  console.log();
  console.log(chalk.cyan.bold('🔐 检查权限'));
  console.log();

  const answers = await inquirer.prompt([
    {
      type: 'input',
      name: 'node',
      message: '节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    },
    {
      type: 'input',
      name: 'target',
      message: '目标节点 ID:',
      validate: (input) => input.length > 0 || 'ID 不能为空'
    },
    {
      type: 'input',
      name: 'action',
      message: '操作 (read/write/admin):',
      default: 'read'
    }
  ]);

  const spinner = ora('检查权限...').start();

  try {
    const result = await request(
      `/permissions/check?node=${answers.node}&target=${answers.target}&action=${answers.action}`
    );
    spinner.succeed();

    const icon = result.data.allowed ? '✅' : '❌';
    console.log(chalk.cyan(`\n  ${icon} 权限检查:`));
    console.log(chalk.gray(`  ${result.data.node} → ${result.data.target}`));
    console.log(chalk.gray(`  操作: ${result.data.action}`));
    console.log(chalk.gray(`  结果: ${result.data.allowed ? '允许' : '拒绝'}\n`));
  } catch (error) {
    spinner.fail(chalk.red(`❌ 检查失败: ${error.message}`));
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// ========== 服务管理命令 ==========
async function showHealth() {
  console.log();
  console.log(chalk.cyan.bold('📊 系统状态'));
  console.log();

  const spinner = ora('检查系统状态...').start();

  try {
    const result = await request('/health');
    spinner.succeed();

    console.log();
    console.log(chalk.cyan('  📊 系统状态:\n'));
    console.log(chalk.gray(`  状态: ${result.status}`));
    console.log();
    console.log(chalk.cyan('  功能:'));
    console.log(chalk.gray(`  REST API:  ${result.features.rest ? '✅' : '❌'}`));
    console.log(chalk.gray(`  WebSocket: ${result.features.websocket ? '✅' : '❌'}`));
    console.log(chalk.gray(`  认证:      ${result.features.auth ? '✅' : '❌'}`));
    console.log();
    console.log(chalk.cyan('  统计:\n'));
    console.log(chalk.gray(`  节点数:    ${result.stats.nodes}`));
    console.log(chalk.gray(`  关系数:    ${result.stats.relations}`));
    console.log(chalk.gray(`  WS 连接:   ${result.stats.wsConnections}\n`));
  } catch (error) {
    spinner.fail(chalk.red(`❌ 连接失败: ${error.message}`));
    console.log(chalk.yellow('\n  💡 请确保 ClawNet 服务正在运行: npm start\n'));
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// ========== 配置管理 ==========
async function configMenu() {
  console.log();
  console.log(chalk.cyan.bold('⚙️  配置管理'));
  console.log();

  const { action } = await inquirer.prompt([
    {
      type: 'list',
      name: 'action',
      message: '配置管理:',
      choices: [
        { name: '🔧 配置服务器地址', value: 'server' },
        { name: '🔑 配置 Token', value: 'token' },
        { name: '📋 查看当前配置', value: 'view' },
        { name: '🔙 返回主菜单', value: 'back' }
      ]
    }
  ]);

  switch (action) {
    case 'server':
      const { url } = await inquirer.prompt([
        {
          type: 'input',
          name: 'url',
          message: '服务器地址:',
          default: CLAWNET_URL
        }
      ]);
      config.url = url;
      saveConfig(config);
      console.log(chalk.green('\n  ✅ 已保存\n'));
      break;

    case 'token':
      const { token } = await inquirer.prompt([
        {
          type: 'password',
          name: 'token',
          message: 'API Token:',
          mask: '*'
        }
      ]);
      config.token = token;
      saveConfig(config);
      console.log(chalk.green('\n  ✅ 已保存\n'));
      break;

    case 'view':
      console.log();
      console.log(chalk.cyan('  当前配置:\n'));
      console.log(chalk.gray(`  服务器: ${config.url || CLAWNET_URL}`));
      console.log(chalk.gray(`  Token:  ${config.token ? '已配置' : '未配置'}`));
      console.log();
      break;

    case 'back':
      return;
  }

  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// 帮助信息
function showHelp() {
  console.log();
  console.log(chalk.cyan('  ❓ 帮助信息'));
  console.log();
  
  console.log(chalk.cyan.bold('  ClawNet 是一个关系驱动的多节点智能协作网络。\n'));
  console.log(chalk.gray('  核心概念:\n'));
  console.log(chalk.gray('  • 节点 - 人、机器人、设备、组织等实体'));
  console.log(chalk.gray('  • 关系 - 节点之间的连接'));
  console.log(chalk.gray('  • 权限 - 基于关系的访问控制\n'));
  console.log(chalk.cyan.bold('  快速开始:\n'));
  console.log(chalk.gray('  1. 创建节点: 节点管理 → 创建节点'));
  console.log(chalk.gray('  2. 建立关系: 关系管理 → 创建关系'));
  console.log(chalk.gray('  3. 检查权限: 权限管理 → 检查权限\n'));
  console.log();
  console.log(chalk.cyan.bold('  文档:\n'));
  console.log(chalk.gray('  GitHub: https://github.com/Bsheepcoder/ClawNet'));
  console.log(chalk.gray('  文档: https://github.com/Bsheepcoder/ClawNet#readme\n'));
  console.log();
}

// 按回车继续
async function pressEnter() {
  await inquirer.prompt([
    {
      type: 'input',
      name: 'continue',
      message: '按回车继续...'
    }
  ]);
}

// 主程序
async function main() {
  try {
    while (true) {
      try {
        const action = await mainMenu();

        switch (action) {
          case 'create-node':
            await createNode();
            break;
          case 'list-nodes':
            await listNodes();
            break;
          case 'get-node':
            await getNode();
            break;
          case 'delete-node':
            await deleteNode();
            break;
          case 'create-relation':
            await createRelation();
            break;
          case 'list-relations':
            await listRelations();
            break;
          case 'cleanup-relations':
            await cleanupRelations();
            break;
          case 'check-permission':
            await checkPermission();
            break;
          case 'health':
            await showHealth();
            break;
          case 'config':
            await configMenu();
            break;
          case 'help':
            showHelp();
            await pressEnter();
            break;
          case 'exit':
            console.log();
            console.log(chalk.cyan('  再见! 👋\n'));
            process.exit(0);
        }
      } catch (error) {
        if (error.message === 'User force closed with prompt with a non-null value') {
          console.log();
          console.log(chalk.cyan('  再见! 👋\n'));
          process.exit(0);
        }
        console.error(chalk.red(`\n  错误: ${error.message}\n`));
      }
    }
  } catch (error) {
    console.error(chalk.red(`\n  致命错误: ${error.message}\n`));
    process.exit(1);
  }
}

main();
