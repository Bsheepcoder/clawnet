{
  "name": "@husile/clawnet",
  "version": "0.5.0",
  "description": "关系驱动的多节点智能协作网络 - Multi-node intelligent collaboration network based on relation graph",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clawnet": "./bin/clawnet"
  },
  "files": [
    "dist/**/*",
    "bin/clawnet",
    "skill/**/*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    ".env.example",
    ".env.production.example"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node dist/test.js",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "cli": "node cli/clawnet.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "relation-network",
    "ai-bot",
    "routing",
    "permission",
    "multi-node",
    "collaboration",
    "wechat",
    "telegram",
    "websocket",
    "graph",
    "topology"
  ],
  "author": "husile",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bsheepcoder/clawnet.git"
  },
  "bugs": {
    "url": "https://github.com/Bsheepcoder/clawnet/issues"
  },
  "homepage": "https://github.com/Bsheepcoder/clawnet#readme",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^9.0.0",
    "cors": "^2.8.0",
    "express": "^4.18.0",
    "ws": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
